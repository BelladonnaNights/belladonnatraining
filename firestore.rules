rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Modules (course content) ──────────────────────────────────────────────
    // Any logged-in user can read modules and videos.
    // Questions are SERVER-ONLY — client can never read correctIndex.
    match /modules/{moduleId} {
      allow read: if request.auth != null;
      allow write: if false; // Use admin SDK or Firebase console only

      match /videos/{videoId} {
        allow read: if request.auth != null;
        allow write: if false;
      }

      // CRITICAL: correctIndex lives here — never readable by client
      match /questions/{questionId} {
        allow read: if false;
        allow write: if false;
      }
    }

    // ── Users ─────────────────────────────────────────────────────────────────
    // Users can only read/write their own profile.
    // Admins can read all users.
    match /users/{uid} {
      allow read: if request.auth.uid == uid
                  || isAdmin();
      allow update: if request.auth.uid == uid
                    && !("role" in request.resource.data)       // can't self-promote
                    && !("certified" in request.resource.data); // can't self-certify
      allow create: if false; // Created by admin SDK
      allow delete: if false;

      // Progress is written only by the submitQuiz Cloud Function (admin SDK)
      match /progress/{moduleId} {
        allow read: if request.auth.uid == uid || isAdmin();
        allow write: if false; // Cloud Function only
      }
    }

    // ── Certifications ────────────────────────────────────────────────────────
    // Trainees can read their own cert doc.
    // Only Cloud Functions (admin SDK) can write.
    match /certifications/{uid} {
      allow read: if request.auth.uid == uid || isAdmin();
      allow write: if false; // Cloud Function only
    }

    // ── Helper ───────────────────────────────────────────────────────────────
    function isAdmin() {
      return request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }
  }
}
